rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /*
      ============================================================
      GLOBAL HELPERS
      ============================================================
    */

    function isSignedIn() {
      return request.auth != null;
    }

    function isConsoleAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'seigendc@gmail.com' ||
        request.auth.token.email == 'seigendcpurestartba@gmail.com' ||
        request.auth.token.email == 'lnyamutsmba@gmail.com' ||
        request.auth.token.email == 'seigencommerce@gmail.com'
      );
    }

    function isSuperAdmin() {
      return isConsoleAdmin();
    }

    /*
      ============================================================
      IMPORTANT STRUCTURE

      1. The non-itred collections below are kept because another app
         in this Firebase project still uses them.

      2. The itred_* collections are for the iTred Vendor Catalogue Engine.

      3. The broad itred_* fallback near the end is only for pilot stability.
         It prevents new itred_* screens from crashing before we add exact
         collection rules.
      ============================================================
    */


    /*
      ============================================================
      EXISTING / SHARED APP COLLECTIONS
      Keep these for the other application.
      ============================================================
    */

    match /app_users/{userId} {
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow get, list, update: if isSignedIn();
      allow delete: if isConsoleAdmin();
    }

    match /vendors/{docId} {
      allow get, list: if true;
      allow create, update: if isSignedIn();
      allow delete: if isConsoleAdmin();
    }

    match /products/{docId} {
      allow get, list: if true;
      allow create, update: if isSignedIn();
      allow delete: if isConsoleAdmin();
    }

    match /catalogues/{docId} {
      allow get, list: if true;
      allow create, update: if isSignedIn();
      allow delete: if isConsoleAdmin();
    }

    match /orders/{docId} {
      allow create: if true;
      allow get, list, update: if isSignedIn();
      allow delete: if isConsoleAdmin();
    }

    match /subscriptions/{docId} {
      allow get, list, create, update: if isSignedIn();
      allow delete: if isConsoleAdmin();
    }

    match /plans/{docId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isConsoleAdmin();
    }

    match /audit_logs/{docId} {
      allow create: if isSignedIn();
      allow get, list: if isConsoleAdmin();
      allow update, delete: if isConsoleAdmin();
    }

    match /console_staff/{docId} {
      allow get, list: if isSignedIn();
      allow create, update: if isSignedIn();
      allow delete: if isConsoleAdmin();
    }

    match /rpn_agents/{docId} {
      allow get, list, create, update: if isSignedIn();
      allow delete: if isSuperAdmin();
    }

    match /rpn_field_operations/{docId} {
      allow get, list, create, update: if isSignedIn();
      allow delete: if isSuperAdmin();
    }

    match /vendor_conversion_center/{docId} {
      allow get, list, create, update: if isSignedIn();
      allow delete: if isSuperAdmin();
    }

    match /vendor_storefronts/{docId} {
      allow get, list: if true;
      allow create, update: if isSignedIn();
      allow delete: if isConsoleAdmin();
    }

    match /storefronts/{docId} {
      allow get, list: if true;
      allow create, update: if isSignedIn();
      allow delete: if isConsoleAdmin();
    }

    match /cah_links/{docId} {
      allow get, list: if true;
      allow create, update: if isSignedIn();
      allow delete: if isConsoleAdmin();
    }

    match /access_hub_links/{docId} {
      allow get, list: if true;
      allow create, update: if isSignedIn();
      allow delete: if isConsoleAdmin();
    }

    match /system_settings/{docId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isConsoleAdmin();
    }


    /*
      ============================================================
      iTRED USERS / STAFF / CONSOLE
      ============================================================
    */

    match /itred_app_users/{docId} {
      allow create: if isSignedIn();
      allow get, list, update: if isSignedIn();
      allow delete: if isConsoleAdmin();
    }

    match /itred_console_staff/{docId} {
      allow get, list, create, update: if isSignedIn();
      allow delete: if isConsoleAdmin();
    }

    match /itred_staff_members/{docId} {
      allow get, list, create, update: if isSignedIn();
      allow delete: if isConsoleAdmin();
    }

    match /itred_staff_registry/{docId} {
      allow get, list, create, update: if isSignedIn();
      allow delete: if isConsoleAdmin();
    }

    match /itred_staff_access_logs/{docId} {
      allow create: if isSignedIn();
      allow get, list: if isSignedIn();
      allow update, delete: if isConsoleAdmin();
    }


    /*
      ============================================================
      iTRED RPN / FIELD OPERATIONS
      ============================================================
    */

    match /itred_rpn_agents/{docId} {
      allow get, list, create, update: if isSignedIn();
      allow delete: if isSuperAdmin();
    }

    match /itred_rpn_field_operations/{docId} {
      allow get, list, create, update: if isSignedIn();
      allow delete: if isSuperAdmin();
    }

    match /itred_vendor_conversion_center/{docId} {
      allow get, list, create, update: if isSignedIn();
      allow delete: if isSuperAdmin();
    }


    /*
      ============================================================
      iTRED VENDORS / PRODUCTS / CATALOGUES
      ============================================================
    */

    match /itred_vendors/{docId} {
      allow get, list: if true;
      allow create, update: if true;
      allow delete: if isConsoleAdmin();
    }

    match /itred_products/{docId} {
      allow get, list: if true;
      allow create, update: if true;
      allow delete: if isConsoleAdmin();
    }

    match /itred_product_intake/{docId} {
      allow get, list, create, update: if isSignedIn();
      allow delete: if isConsoleAdmin();
    }

    match /itred_catalogues/{docId} {
      allow get, list: if true;
      allow create, update: if true;
      allow delete: if isConsoleAdmin();
    }

    match /itred_catalogue_history/{docId} {
      allow get, list, create, update: if isSignedIn();
      allow delete: if isConsoleAdmin();
    }

    match /itred_catalogue_deployments/{docId} {
      allow get, list: if true;
      allow create, update: if isSignedIn();
      allow delete: if isConsoleAdmin();
    }


    /*
      ============================================================
      iTRED STOREFRONTS / HTML EXPORTS
      ============================================================
    */

    match /itred_storefronts/{docId} {
      allow get, list: if true;
      allow create, update: if true;
      allow delete: if isConsoleAdmin();
    }


    /*
      ============================================================
      iTRED PRICING / SUBSCRIPTIONS / COLLECTIONS
      ============================================================
    */

    match /itred_pricing_plans/{docId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isConsoleAdmin();
    }

    match /itred_subscriptions/{docId} {
      allow get, list, create, update: if isSignedIn();
      allow delete: if isConsoleAdmin();
    }

    match /itred_collections/{docId} {
      allow get, list, create, update: if isSignedIn();
      allow delete: if isConsoleAdmin();
    }

    match /itred_activation_requests/{docId} {
      allow get, list, create, update: if isSignedIn();
      allow delete: if isConsoleAdmin();
    }


    /*
      ============================================================
      iTRED ACCESS HUB / WHATSAPP / CAH LINKS
      ============================================================
    */

    match /itred_cah_links/{docId} {
      allow get, list: if true;
      allow create, update: if isSignedIn();
      allow delete: if isConsoleAdmin();
    }

    match /itred_whatsapp_groups/{docId} {
      allow get, list: if true;
      allow create, update: if isSignedIn();
      allow delete: if isConsoleAdmin();
    }

    match /itred_whatsapp_channels/{docId} {
      allow get, list: if true;
      allow create, update: if isSignedIn();
      allow delete: if isConsoleAdmin();
    }

    match /itred_whatsapp_campaigns/{docId} {
      allow get, list: if true;
      allow create, update: if isSignedIn();
      allow delete: if isConsoleAdmin();
    }

    match /itred_group_daily_logs/{docId} {
      allow get, list, create, update: if isSignedIn();
      allow delete: if isConsoleAdmin();
    }

    match /itred_vendor_response_logs/{docId} {
      allow get, list, create, update: if isSignedIn();
      allow delete: if isConsoleAdmin();
    }

    match /itred_rpn_distribution_logs/{docId} {
      allow get, list, create, update: if isSignedIn();
      allow delete: if isConsoleAdmin();
    }

    match /itred_community_moderation_logs/{docId} {
      allow get, list, create, update: if isSignedIn();
      allow delete: if isConsoleAdmin();
    }


    /*
      ============================================================
      iTRED ANALYTICS / ACTIVITY / BI
      ============================================================
    */

    match /itred_activity_logs/{docId} {
      allow get, list, create: if isSignedIn();
      allow update, delete: if isConsoleAdmin();
    }

    match /itred_audit_logs/{docId} {
      allow create: if isSignedIn();
      allow get, list: if isConsoleAdmin();
      allow update, delete: if isConsoleAdmin();
    }

    match /itred_analytics_events/{docId} {
      allow create: if true;
      allow get, list: if isSignedIn();
      allow update, delete: if isConsoleAdmin();
    }

    match /itred_whatsapp_hits/{docId} {
      allow create: if true;
      allow get, list: if isSignedIn();
      allow update, delete: if isConsoleAdmin();
    }

    match /itred_link_click_events/{docId} {
      allow create: if true;
      allow get, list: if isSignedIn();
      allow update, delete: if isConsoleAdmin();
    }

    match /itred_product_view_events/{docId} {
      allow create: if true;
      allow get, list: if isSignedIn();
      allow update, delete: if isConsoleAdmin();
    }

    match /itred_catalogue_view_events/{docId} {
      allow create: if true;
      allow get, list: if isSignedIn();
      allow update, delete: if isConsoleAdmin();
    }

    match /itred_whatsapp_enquiry_events/{docId} {
      allow create: if true;
      allow get, list: if isSignedIn();
      allow update, delete: if isConsoleAdmin();
    }

    match /itred_phone_call_events/{docId} {
      allow create: if true;
      allow get, list: if isSignedIn();
      allow update, delete: if isConsoleAdmin();
    }

    match /itred_share_events/{docId} {
      allow create: if true;
      allow get, list: if isSignedIn();
      allow update, delete: if isConsoleAdmin();
    }

    match /itred_offline_catalogue_downloads/{docId} {
      allow create: if true;
      allow get, list: if isSignedIn();
      allow update, delete: if isConsoleAdmin();
    }


    /*
      ============================================================
      iTRED LEADS / REPORTS / DEMAND TAGS
      ============================================================
    */

    match /itred_leads/{docId} {
      allow create: if true;
      allow get, list: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isConsoleAdmin();
    }

    match /itred_leads_center/{docId} {
      allow get, list, create, update: if isSignedIn();
      allow delete: if isSuperAdmin();
    }

    match /itred_vendor_reports/{docId} {
      allow get, list, create, update: if isSignedIn();
      allow delete: if isConsoleAdmin();
    }

    match /itred_sector_reports/{docId} {
      allow get, list, create, update: if isSignedIn();
      allow delete: if isConsoleAdmin();
    }

    match /itred_sector_demand_tags/{docId} {
      allow get, list: if true;
      allow create, update: if isSignedIn();
      allow delete: if isConsoleAdmin();
    }


    /*
      ============================================================
      iTRED SETTINGS
      ============================================================
    */

    match /itred_settings/{docId} {
      allow get, list: if true;
      allow create, update: if isSignedIn();
      allow delete: if isConsoleAdmin();
    }

    match /itred_system_settings/{docId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isConsoleAdmin();
    }


    /*
      ============================================================
      iTRED POS / ACCOUNTING EXTENSION COLLECTIONS
      ============================================================
    */

    match /itred_pos_terminals/{docId} {
      allow get, list, create, update: if isSignedIn();
      allow delete: if isConsoleAdmin();
    }

    match /itred_pos_shifts/{docId} {
      allow get, list, create, update: if isSignedIn();
      allow delete: if isConsoleAdmin();
    }

    match /itred_pos_events/{docId} {
      allow get, list, create: if isSignedIn();
      allow update, delete: if isConsoleAdmin();
    }

    match /itred_pos_sales/{docId} {
      allow get, list, create, update: if isSignedIn();
      allow delete: if isConsoleAdmin();
    }

    match /itred_pos_sale_items/{docId} {
      allow get, list, create: if isSignedIn();
      allow update, delete: if isConsoleAdmin();
    }

    match /itred_pos_return_requests/{docId} {
      allow get, list, create, update: if isSignedIn();
      allow delete: if isConsoleAdmin();
    }

    match /itred_inventory_ledger/{docId} {
      allow get, list, create: if isSignedIn();
      allow update, delete: if isConsoleAdmin();
    }

    match /itred_chart_accounts/{docId} {
      allow get, list, create, update: if isSignedIn();
      allow delete: if isConsoleAdmin();
    }

    match /itred_accounting_journals/{docId} {
      allow get, list, create, update: if isSignedIn();
      allow delete: if isConsoleAdmin();
    }

    match /itred_journal_lines/{docId} {
      allow get, list, create: if isSignedIn();
      allow update, delete: if isConsoleAdmin();
    }


    /*
      ============================================================
      SAFETY NET FOR FUTURE iTRED COLLECTIONS ONLY

      This does not affect the other application because it only matches
      collection names starting with itred_.
      ============================================================
    */

    match /{collectionId}/{docId} {
      allow get, list: if collectionId.matches('^itred_.*');
      allow create, update: if collectionId.matches('^itred_.*') && isSignedIn();
      allow delete: if collectionId.matches('^itred_.*') && isConsoleAdmin();
    }



    /*
      ============================================================
      iTRED STAFF / CONSOLE STAFF
      ============================================================
    */

    
    /*
      ============================================================
      iTRED STAFF / CONSOLE STAFF - PILOT OPEN WRITE
      TODO: tighten before production.
      ============================================================
    */

    
    /*
      ============================================================
      iTRED STAFF / CONSOLE STAFF - PILOT OPEN WRITE
      TODO: tighten before production.
      ============================================================
    */

    match /itred_console_staff/{staffId} {
      allow get, list: if true;
      allow create, update: if true;
      allow delete: if isConsoleAdmin();
    }

    match /itred_staff_members/{staffId} {
      allow get, list: if true;
      allow create, update: if true;
      allow delete: if isConsoleAdmin();
    }

    match /itred_staff_registry/{staffId} {
      allow get, list: if true;
      allow create, update: if true;
      allow delete: if isConsoleAdmin();
    }

    match /itred_staff_access_logs/{logId} {
      allow get, list: if true;
      allow create, update: if true;
      allow delete: if isConsoleAdmin();
    }

    match /itred_system_settings/{settingId} {
      allow get, list: if true;
      allow create, update: if true;
      allow delete: if isConsoleAdmin();
    }

    /*
      ============================================================
      DEFAULT DENY FOR EVERYTHING ELSE
      ============================================================
    */

    match /{document=**} {
      allow read, write: if false;
    }
  }
}