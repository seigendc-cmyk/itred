rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // TEMP DEV ONLY - Fallback for missing vendorId records
    match /itred_activity_logs/{docId} {
      allow read, list, create, update: if request.auth != null;
      allow delete: if request.auth != null; // Simplified dev fallback
    }
    match /itred_catalogue_history/{docId} {
      allow read, list, create, update: if request.auth != null;
      allow delete: if request.auth != null;
    }
    match /itred_vendors/{docId} {
      allow read, list, create, update: if request.auth != null;
      allow delete: if request.auth != null;
    }
    match /itred_product_intake/{productId} {
      allow read, list, create, update: if request.auth != null;
      allow delete: if request.auth != null;
    }
  }
}